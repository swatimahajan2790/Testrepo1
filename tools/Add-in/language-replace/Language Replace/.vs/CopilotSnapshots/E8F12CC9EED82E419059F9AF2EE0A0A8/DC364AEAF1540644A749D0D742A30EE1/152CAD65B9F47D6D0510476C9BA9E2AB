<Window x:Class="Language_Replace.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Language Replace Tool - AI Powered"
        WindowStartupLocation="CenterScreen"
        Width="700"
        Height="850"
        ScrollViewer.VerticalScrollBarVisibility="Auto"
        ScrollViewer.HorizontalScrollBarVisibility="Auto" 
        Icon="/version_2025;component/DAR_LOGO_BLACK.RGB.png">

    <Grid Background="#F5F5F5">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                
                <TextBlock Text="Language Replace - AI Translation" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#333333"
                           Margin="0,0,0,15"/>

                <!-- Mode Selection -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="1. Select Translation Mode" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,12"/>

                        <RadioButton x:Name="FileBasedRadio" 
                                     GroupName="TranslationMode"
                                     IsChecked="True"
                                     Margin="0,0,0,10">
                            <TextBlock Text="File-Based: Load CSV translations" Foreground="#333333"/>
                        </RadioButton>

                        <RadioButton x:Name="AITranslationRadio" 
                                     GroupName="TranslationMode"
                                     Checked="AITranslationRadio_Checked">
                            <TextBlock Text="AI Translation: Use NLLB Model (Recommended)" Foreground="#333333"/>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- File-Based Section -->
                <Border x:Name="FileModeSection" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="2. Load Translation File" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="FilePathTextBox" 
                                     Text="{Binding ExcelFilePath, UpdateSourceTrigger=PropertyChanged}"
                                     Height="35"
                                     Padding="10,8"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Background="White"
                                     Foreground="#666666"
                                     Margin="0,0,10,0"/>
                            <Button x:Name="BrowseButton" 
                                    Content="Browse..." 
                                    Click="BrowseButton_Click"
                                    Width="100"
                                    Height="35"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Cursor="Hand"/>
                        </StackPanel>

                        <TextBlock Text="Supported: CSV format" 
                                   FontSize="11" 
                                   Foreground="#999999"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- AI Translation Section -->
                <Border x:Name="AIModeSection" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="2. Select Target Language" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,12"/>

                        <ComboBox x:Name="LanguageComboBox"
                                  ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage, UpdateSourceTrigger=PropertyChanged}"
                                  Height="35"
                                  Padding="10,8"
                                  Margin="0,0,0,10"
                                  Background="White">
                        </ComboBox>

                        <TextBlock Text="{Binding ModelStatus, StringFormat='Model Status: {0}'}" 
                                   FontSize="11" 
                                   Foreground="#666666"
                                   Margin="0,0,0,10"/>

                        <Button x:Name="LoadModelButton" 
                                Content="Load NLLB Model" 
                                Click="LoadModelButton_Click"
                                Height="35"
                                Background="#FF9800"
                                Foreground="White"
                                FontWeight="Bold"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Replacement Options -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="3. Replacement Strategy" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,12"/>

                        <RadioButton x:Name="Option1Radio" 
                                     GroupName="ReplacementOptions"
                                     Margin="0,0,0,10">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Replace All Occurrences" 
                                           FontWeight="Bold" 
                                           Foreground="#333333"/>
                                <TextBlock Text="Replaces all text matches" 
                                           FontSize="11" 
                                           Foreground="#666666"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="Option2Radio" 
                                     GroupName="ReplacementOptions">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Exact Match Only" 
                                           FontWeight="Bold" 
                                           Foreground="#333333"/>
                                <TextBlock Text="Replaces exact parameter values" 
                                           FontSize="11" 
                                           Foreground="#666666"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- Additional Options -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="4. Options" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,12"/>

                        <CheckBox x:Name="CaseSensitiveCheckBox" 
                                  IsChecked="{Binding IsCaseSensitive, UpdateSourceTrigger=PropertyChanged}">
                            <TextBlock Text="Case Sensitive Matching" Foreground="#333333"/>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- Translation Preview -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="5. Translation Preview" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding Translations.Count, StringFormat='Translations: {0}'}" 
                                   FontSize="12" 
                                   Foreground="#666666"
                                   Margin="0,0,0,10"/>

                        <DataGrid x:Name="TranslationGrid"
                                  ItemsSource="{Binding Translations}"
                                  Height="150"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  Background="White">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Original" 
                                                    Binding="{Binding OriginalText}" 
                                                    Width="*"
                                                    IsReadOnly="True"/>
                                <DataGridTextColumn Header="Translated" 
                                                    Binding="{Binding TranslatedText}" 
                                                    Width="*"
                                                    IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="ApplyButton" 
                            Content="Apply Replacements" 
                            Click="ApplyButton_Click"
                            Padding="20,12"
                            Background="#2196F3"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="12"
                            Cursor="Hand"
                            Margin="0,0,10,0"
                            Grid.Column="0"/>
                    <Button x:Name="CloseButton" 
                            Content="Close" 
                            Click="CloseButton_Click"
                            Padding="20,12"
                            Background="#757575"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="12"
                            Cursor="Hand"
                            Grid.Column="1"/>
                </Grid>

                <!-- Status Message -->
                <TextBlock x:Name="StatusTextBlock" 
                           Text=""
                           FontSize="11" 
                           Foreground="#F44336"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</Window>
