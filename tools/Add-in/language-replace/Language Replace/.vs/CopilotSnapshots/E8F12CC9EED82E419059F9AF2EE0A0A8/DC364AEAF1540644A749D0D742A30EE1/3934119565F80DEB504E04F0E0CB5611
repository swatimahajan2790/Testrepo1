using Autodesk.Revit.UI;
using System;
using System.ComponentModel;
using System.Runtime.CompilerServices;
using System.Windows;
using System.Windows.Forms;
using System.Windows.Media;
using Color = System.Windows.Media.Color;

namespace Language_Replace
{
    public partial class Main : Window, INotifyPropertyChanged
    {
        private readonly UIDocument _uidoc;
        private readonly Data _data;
        private readonly ExternalEvent _applyEvent;
        private readonly ApplyHandler _handler;

        public event PropertyChangedEventHandler? PropertyChanged;

        public Main(Data data, UIDocument uidoc, ExternalEvent applyEvent, ApplyHandler handler)
        {
            InitializeComponent();
            _uidoc = uidoc;
            _data = data;
            _applyEvent = applyEvent;
            _handler = handler;

            DataContext = _data;
            Option1Radio.IsChecked = true;
        }

        private void BrowseButton_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                var openFileDialog = new OpenFileDialog
                {
                    Title = "Select Translation File",
                    Filter = "CSV Files (*.csv)|*.csv|All Files (*.*)|*.*",
                    InitialDirectory = Environment.GetFolderPath(Environment.SpecialFolder.Desktop)
                };

                if (openFileDialog.ShowDialog() == System.Windows.Forms.DialogResult.OK)
                {
                    var filePath = openFileDialog.FileName;
                    _data.ExcelFilePath = filePath;

                    try
                    {
                        var translations = ExcelHelper.ReadTranslationsFromExcel(filePath);
                        _data.Translations.Clear();

                        foreach (var translation in translations)
                            _data.Translations.Add(translation);

                        StatusTextBlock.Text = $"Loaded {translations.Count} translations";
                        StatusTextBlock.Foreground = new SolidColorBrush(Color.FromRgb(76, 175, 80));
                    }
                    catch (Exception ex)
                    {
                        StatusTextBlock.Text = $"Error loading file: {ex.Message}";
                        StatusTextBlock.Foreground = new SolidColorBrush(Color.FromRgb(244, 67, 54));
                    }
                }
            }
            catch (Exception ex)
            {
                StatusTextBlock.Text = $"Error: {ex.Message}";
                StatusTextBlock.Foreground = new SolidColorBrush(Color.FromRgb(244, 67, 54));
            }
        }

        private void ApplyButton_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                if (_data.Translations.Count == 0)
                {
                    StatusTextBlock.Text = "No translations loaded.";
                    StatusTextBlock.Foreground = new SolidColorBrush(Color.FromRgb(244, 67, 54));
                    return;
                }

                if (Option1Radio.IsChecked == true)
                    _data.SelectedOption = Data.ReplacementOption.ReplaceToSecondLanguage;
                else if (Option2Radio.IsChecked == true)
                    _data.SelectedOption = Data.ReplacementOption.ReplaceToExistingOrSecond;

                ApplyButton.IsEnabled = false;
                BrowseButton.IsEnabled = false;
                StatusTextBlock.Text = "Processing...";
                StatusTextBlock.Foreground = new SolidColorBrush(Color.FromRgb(33, 150, 243));

                _applyEvent.Raise();

                Dispatcher.BeginInvoke(new Action(() =>
                {
                    ApplyButton.IsEnabled = true;
                    BrowseButton.IsEnabled = true;
                }), System.Windows.Threading.DispatcherPriority.Background);
            }
            catch (Exception ex)
            {
                StatusTextBlock.Text = $"Error: {ex.Message}";
                StatusTextBlock.Foreground = new SolidColorBrush(Color.FromRgb(244, 67, 54));
                ApplyButton.IsEnabled = true;
                BrowseButton.IsEnabled = true;
            }
        }

        private void CloseButton_Click(object sender, RoutedEventArgs e)
        {
            Close();
        }

        protected void OnPropertyChanged([CallerMemberName] string name = null)
        {
            PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(name));
        }
    }
}