    public static class ExcelHelper
    {
        /// <summary>
        /// Reads translation data from an Excel file (CSV format or Excel format)
        /// Expected format: Column A = Original Text, Column B = Translated Text
        /// </summary>
        public static List<TranslationEntry> ReadTranslationsFromExcel(string filePath)
        {
            var translations = new List<TranslationEntry>();

            if (!File.Exists(filePath))
                throw new FileNotFoundException($"File not found: {filePath}");

            try
            {
                if (filePath.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
                {
                    translations = ReadCsv(filePath);
                }
                else if (filePath.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase) ||
                         filePath.EndsWith(".xls", StringComparison.OrdinalIgnoreCase))
                {
                    translations = ReadExcelFile(filePath);
                }
                else
                {
                    // Try CSV format as default
                    translations = ReadCsv(filePath);
                }
            }
            catch (Exception ex)
            {
                throw new Exception($"Error reading Excel file: {ex.Message}", ex);
            }

            return translations;
        }

        private static List<TranslationEntry> ReadCsv(string filePath)
        {
            var translations = new List<TranslationEntry>();

            try
            {
                using (var reader = new StreamReader(filePath))
                {
                    string line;
                    int lineNumber = 0;

                    while ((line = reader.ReadLine()) != null)
                    {
                        lineNumber++;

                        // Skip empty lines and headers
                        if (string.IsNullOrWhiteSpace(line) || lineNumber == 1)
                            continue;

                        var parts = line.Split(new[] { ',' }, StringSplitOptions.None);
                        if (parts.Length >= 2)
                        {
                            var original = parts[0]?.Trim().Trim('"');
                            var translated = parts[1]?.Trim().Trim('"');

                            if (!string.IsNullOrEmpty(original) && !string.IsNullOrEmpty(translated))
                            {
                                translations.Add(new TranslationEntry
                                {
                                    OriginalText = original,
                                    TranslatedText = translated
                                });
                            }
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                throw new Exception($"Error reading CSV file: {ex.Message}", ex);
            }

            return translations;
        }

