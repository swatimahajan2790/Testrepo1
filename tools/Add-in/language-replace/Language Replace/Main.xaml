<Window x:Class="Language_Replace.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Language Replace"
        WindowStartupLocation="CenterScreen"
        Width="700"
        Height="850"
        ScrollViewer.VerticalScrollBarVisibility="Auto"
        ScrollViewer.HorizontalScrollBarVisibility="Auto" 
        Icon="/version_2025;component/DAR_LOGO_BLACK.RGB.png">

    <Grid Background="#F5F5F5">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                
                <TextBlock Text="Language Replace" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#333333"
                           Margin="0,0,0,15"/>

                <Border x:Name="FileModeSection" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="1. Load Translation File" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="FilePathTextBox" 
                                     Text="{Binding ExcelFilePath, UpdateSourceTrigger=PropertyChanged}"
                                     Height="35"
                                     Padding="10,8"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Background="White"
                                     Foreground="#666666"
                                     Margin="0,0,10,0"/>
                            <Button x:Name="BrowseButton" 
                                    Content="Browse..." 
                                    Click="BrowseButton_Click"
                                    Width="100"
                                    Height="35"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Cursor="Hand"/>
                        </StackPanel>


                        <TextBlock Text="Supported: Excel — Column B = Original, Column C = Translation (Column A ignored)" 
           FontSize="11" 
           Foreground="#999999"
           FontStyle="Italic"/>

                    </StackPanel>
                </Border>


                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="2. Replacement Strategy" 
                   FontSize="14" 
                   FontWeight="Bold" 
                   Foreground="#333333"
                   Margin="0,0,0,12"/>

                        <RadioButton x:Name="Option1Radio" 
                     GroupName="ReplacementOptions"
                     Margin="0,0,0,10">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Replace to translation" 
                           FontWeight="Bold" 
                           Foreground="#333333"/>
                                <TextBlock Text="Replace original text with translation from file" 
                           FontSize="11" 
                           Foreground="#666666"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="Option2Radio" 
                     GroupName="ReplacementOptions">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Combine Original/Translation" 
                           FontWeight="Bold" 
                           Foreground="#333333"/>
                                <TextBlock Text="Combine using '/' separator (original/translation)" 
                           FontSize="11" 
                           Foreground="#666666"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="3. Scope"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="#333333"
                   Margin="0,0,0,12"/>
                        <RadioButton x:Name="ScopeAllRadio"
                     GroupName="ReplaceScope"
                     Margin="0,0,0,8">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="All text notes in model"
                           FontWeight="Bold"
                           Foreground="#333333"/>
                                <TextBlock Text="Scan the entire model"
                           FontSize="11"
                           Foreground="#666666"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="ScopeSelectedRadio"
                     GroupName="ReplaceScope"
                     Margin="0,0,0,8">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Only selected text notes"
                           FontWeight="Bold"
                           Foreground="#333333"/>
                                <TextBlock Text="Operate only on selection (default)"
                           FontSize="11"
                           Foreground="#666666"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <!--<RadioButton x:Name="ScopePresentInExcelRadio"
                     GroupName="ReplaceScope">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="Only notes present in Excel"
                           FontWeight="Bold"
                           Foreground="#333333"/>
                                <TextBlock Text="Inspect only those whose text exists in the Excel mapping"
                           FontSize="11"
                           Foreground="#666666"
                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </RadioButton>-->
                    </StackPanel>
                </Border>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="4. Translation Preview" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding Translations.Count, StringFormat='Translations: {0}'}" 
                                   FontSize="12" 
                                   Foreground="#666666"
                                   Margin="0,0,0,10"/>

                        <DataGrid x:Name="TranslationGrid"
                                  ItemsSource="{Binding Translations}"
                                  Height="150"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  Background="White">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Width="30" IsReadOnly="False">
                                    <DataGridCheckBoxColumn.ElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.ElementStyle>
                                    <DataGridCheckBoxColumn.EditingElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.EditingElementStyle>
                                </DataGridCheckBoxColumn>
                                <DataGridTextColumn Header="Original" 
                                                    Binding="{Binding Original}" 
                                                    Width="*"
                                                    IsReadOnly="True"/>
                                <DataGridTextColumn Header="Translated" 
                                                    Binding="{Binding Translation}" 
                                                    Width="*"
                                                    IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="ApplyButton" 
                            Content="Apply Replacements" 
                            Click="ApplyButton_Click"
                            Padding="20,12"
                            Background="#2196F3"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="12"
                            Cursor="Hand"
                            Margin="0,0,10,0"
                            Grid.Column="0"/>
                    <Button x:Name="CloseButton" 
                            Content="Close" 
                            Click="CloseButton_Click"
                            Padding="20,12"
                            Background="#757575"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="12"
                            Cursor="Hand"
                            Grid.Column="1"/>
                </Grid>

                <TextBlock x:Name="StatusTextBlock" 
                           Text=""
                           FontSize="11" 
                           Foreground="#F44336"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</Window>
